{
  "name": "realwe",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng serve --host 0.0.0.0",
    "start": "npm run start:production",
    "dev": "npm run start:development",
    "start:production": "NODE_ENV=production ng serve",
    "start:development": "NODE_ENV=development ng serve --host 0.0.0.0 --port 4200",
    "build": "NODE_ENV=production ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "npx eslint --fix src/",
    "format": "prettier --write \"src/**/*.{ts,js,json,html,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,html,scss}\""
  },
  "engines": {
    "node": "22.21.0"
  },
  "private": true,
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@angular/animations": "^21.2.1",
    "@angular/cdk": "^21.2.1",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^18.0.0",
    "@angular-eslint/eslint-plugin-template": "^18.0.0",
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "@ngx-env/builder": "^21.0.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-unused-imports": "^4.1.4",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
